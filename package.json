{
  "name": "topaz-azure-emulator",
  "displayName": "Topaz Azure Emulator",
  "description": "Local Azure development with Topaz — explore resources without leaving VS Code",
  "version": "1.0.0",
  "publisher": "TheCloudTheory",
  "engines": { "vscode": "^1.90.0" },
  "categories": ["Other"],
  "repository": {
    "type": "git",
    "url": "https://github.com/TheCloudTheory/topaz-vscode-extension"
  },
  "license": "Apache-2.0",
  "icon": "resources/topaz-logo.png",
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Topaz",
      "properties": {
        "topaz.baseUrl": {
          "type": "string",
          "default": "https://topaz.local.dev:8899",
          "description": "Base URL of the running Topaz instance"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "topaz",
          "title": "Topaz",
          "icon": "resources/topaz-logo.svg"
        }
      ]
    },
    "views": {
      "topaz": [
        {
          "id": "topazResources",
          "name": "Resources"
        },
        {
          "id": "topazByServiceType",
          "name": "By Service Type"
        }
      ]
    },
    "commands": [
      {
        "command": "topaz.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Topaz"
      },
      {
        "command": "topaz.createManagementGroup",
        "title": "Create Management Group",
        "icon": "$(organization)",
        "category": "Topaz"
      },
      {
        "command": "topaz.createSubscription",
        "title": "Create Subscription",
        "icon": "$(add)",
        "category": "Topaz"
      },
      {
        "command": "topaz.createResourceGroup",
        "title": "Create Resource Group",
        "icon": "$(add)",
        "category": "Topaz"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "topaz.refresh",
          "when": "view == topazResources",
          "group": "navigation"
        },
        {
          "command": "topaz.refresh",
          "when": "view == topazByServiceType",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "topaz.createManagementGroup",
          "when": "view == topazResources && viewItem == managementGroup",
          "group": "inline@1"
        },
        {
          "command": "topaz.createSubscription",
          "when": "view == topazResources && viewItem == managementGroup",
          "group": "inline@2"
        },
        {
          "command": "topaz.createResourceGroup",
          "when": "view == topazResources && viewItem == subscription",
          "group": "inline@1"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
